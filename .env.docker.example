# Copy this to .env.docker, then (optionally) paste in the shared AI keys.
# Docker Compose loads this file into the app and queue containers.
#
#   cp .env.docker.example .env.docker
#
# The app runs fine without the AI keys — résumé↔job matching simply
# stays empty until they are provided.

APP_NAME=GradConnect
APP_ENV=local
APP_KEY=base64:mag7W65vnJkPznP586Kd3qEVeCmsxm3z2X58ssGlrH0=
APP_DEBUG=true
APP_URL=http://localhost:8000

# These point at the bundled Postgres (pgvector) container — leave as-is.
DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=gradconnect
DB_USERNAME=gradconnect
DB_PASSWORD=secret

SESSION_DRIVER=database
QUEUE_CONNECTION=database
CACHE_STORE=database
FILESYSTEM_DISK=local

# ── AI matching (free tiers) ──────────────────────────────────────────
# Paste the shared keys here. Without them the app still works; only the
# AI recommendations/matches stay empty.
AI_EMBEDDING_PROVIDER=gemini
AI_EMBEDDING_DIM=768
AI_SCORING_PROVIDER=groq
AI_SCORING_FALLBACK=gemini

GEMINI_API_KEY=
GEMINI_CHAT_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
